generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum RoleName {
  STUDENT
  STAFF
  COORDINATOR
  ADMIN
}

enum RequestStatus {
  DRAFT
  SUBMITTED
  IN_REVIEW
  PENDING_DOCUMENTS
  APPROVED
  REJECTED
  CANCELLED
}

enum NotificationChannel {
  EMAIL
  SYSTEM
}

enum OfficialDocumentType {
  CERTIFICATE
  TRANSCRIPT
  RESOLUTION
  CONSTANCY
  OTHER
}

model Role {
  id        String   @id @default(uuid())
  name      RoleName @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users     User[]

  @@map("roles")
}

model User {
  id             String           @id @default(uuid())
  email          String           @unique
  passwordHash   String           @map("password_hash")
  fullName       String           @map("full_name")
  documentNumber String           @map("document_number")
  isActive       Boolean          @default(true) @map("is_active")
  roleId         String           @map("role_id")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  role           Role             @relation(fields: [roleId], references: [id])
  studentProfile StudentProfile?
  requests       Request[]
  refreshTokens  RefreshToken[]
  notifications  Notification[]
  requestHistory RequestHistory[]
  uploadedAttachments    Attachment[]       @relation("AttachmentUploader")
  officialDocuments      OfficialDocument[] @relation("OfficialDocumentGenerator")

  @@map("users")
}

model StudentProfile {
  id           String @id @default(uuid())
  userId       String @unique @map("user_id")
  program      String
  semester     Int
  studentCode  String @map("student_code")

  user         User   @relation(fields: [userId], references: [id])

  @@map("student_profiles")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  tokenHash String   @map("token_hash")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id])

  @@index([tokenHash])
  @@map("refresh_tokens")
}

model RequestType {
  id             String   @id @default(uuid())
  name           String   @unique
  description    String?
  estimatedDays  Int      @map("estimated_days")
  isActive       Boolean  @default(true) @map("is_active")

  requests       Request[]

  @@map("request_types")
}

model Request {
  id              String        @id @default(uuid())
  trackingNumber  String        @unique @map("tracking_number")
  title           String
  description     String?
  status          RequestStatus @default(DRAFT)
  userId          String        @map("user_id")
  requestTypeId   String        @map("request_type_id")
  assignedTo      String?       @map("assigned_to")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  user            User          @relation(fields: [userId], references: [id])
  requestType     RequestType   @relation(fields: [requestTypeId], references: [id])
  attachments     Attachment[]
  notifications   Notification[]
  history         RequestHistory[]
  officialDocuments OfficialDocument[]

  @@index([userId])
  @@index([status])
  @@index([requestTypeId])
  @@index([createdAt(sort: Desc)])
  @@index([userId, status, createdAt(sort: Desc)])
  @@map("requests")
}

model Attachment {
  id           String   @id @default(uuid())
  requestId    String   @map("request_id")
  fileName     String   @map("file_name")
  originalName String   @map("original_name")
  url          String
  mimeType     String   @map("mime_type")
  fileSize     Int      @map("file_size")
  provider     String   @default("local")
  uploadedBy   String   @map("uploaded_by")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  request      Request  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  uploader     User     @relation("AttachmentUploader", fields: [uploadedBy], references: [id])

  @@index([requestId])
  @@index([requestId, createdAt(sort: Desc)])
  @@index([uploadedBy])
  @@map("attachments")
}

model Notification {
  id        String             @id @default(uuid())
  userId    String             @map("user_id")
  requestId String?            @map("request_id")
  channel   NotificationChannel
  subject   String
  sent      Boolean            @default(false)
  createdAt DateTime           @default(now()) @map("created_at")

  user      User               @relation(fields: [userId], references: [id])
  request   Request?           @relation(fields: [requestId], references: [id])

  @@index([userId])
  @@index([requestId])
  @@index([sent])
  @@map("notifications")
}

model RequestHistory {
  id              String        @id @default(uuid())
  requestId       String        @map("request_id")
  previousStatus  RequestStatus? @map("previous_status")
  newStatus       RequestStatus  @map("new_status")
  userId          String?       @map("user_id")
  comment         String?
  createdAt       DateTime      @default(now()) @map("created_at")

  request         Request       @relation(fields: [requestId], references: [id], onDelete: Cascade)
  user            User?         @relation(fields: [userId], references: [id])

  @@index([requestId])
  @@index([requestId, createdAt(sort: Desc)])
  @@map("request_history")
}

model OfficialDocument {
  id          String               @id @default(uuid())
  requestId   String               @map("request_id")
  version     Int                  @default(1)
  type        OfficialDocumentType
  snapshotData Json?               @map("snapshot_data")
  fileName    String               @map("file_name")
  filePath    String               @map("file_path")
  fileSize    Int                  @map("file_size")
  provider    String               @default("local")
  generatedBy String?              @map("generated_by")
  notes       String?
  createdAt   DateTime             @default(now()) @map("created_at")
  updatedAt   DateTime             @updatedAt @map("updated_at")

  request     Request              @relation(fields: [requestId], references: [id])
  generator   User?                @relation("OfficialDocumentGenerator", fields: [generatedBy], references: [id])

  @@unique([requestId, version])
  @@index([requestId])
  @@index([requestId, version(sort: Desc)])
  @@index([type])
  @@index([createdAt(sort: Desc)])
  @@map("official_documents")
}
